# IronLedger — environment configuration template
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to version control (it is already in .gitignore).

# ── Network ───────────────────────────────────────────────────────────────────
# Alchemy or Infura HTTPS endpoint for the Sepolia testnet.
# Example (Alchemy): https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Example (Infura):  https://sepolia.infura.io/v3/YOUR_PROJECT_ID
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── Wallet ────────────────────────────────────────────────────────────────────
# Raw 64-character hex private key of the wallet that will sign transactions.
# Do NOT include the 0x prefix.
# Fund this address with Sepolia ETH from https://sepoliafaucet.com before running.
PRIVATE_KEY=your_64_character_hex_private_key_no_0x_prefix

# ── Deployed Contract Addresses ───────────────────────────────────────────────
# Paste the addresses printed by `npx hardhat run scripts/deploy.js --network sepolia`
# All values must start with 0x and be 42 characters long.

# Address of the deployed EquipmentRegistry.sol
REGISTRY_CONTRACT_ADDRESS=0xYourEquipmentRegistryAddressHere

# Address of the deployed InspectionLog.sol
INSPECTION_CONTRACT_ADDRESS=0xYourInspectionLogAddressHere

# Address of the deployed OwnershipTransfer.sol
TRANSFER_CONTRACT_ADDRESS=0xYourOwnershipTransferAddressHere
